# Ignore all files by default, but scan all directories.
*
!*/

# Do not ignore git files in the root of the repo.
!/.git*

# Do not ignore current project's `.uproject`.
!/*.uproject

# Do not ignore source, config, plugins, and tools dirs.
!/Source/**
!/Config/**
!/Plugins/**
!/Tools/**

Build/
Binaries/
Binaries/Win64/
Intermediate/

Content/
# Only allow .uasset and .umap files from /Content dir.
# They're tracked by git-lfs, don't forget to track other
# files if adding them here.
!/Content/Mods/*
!/Content/ModKit/*
# Allow Python scripts in Content/Python/ (mod tooling, not LFS).
!/Content/Python/*.py
# ACL Plugin is needed in this path
!/Content/Editor/ACLPlugin

# Allow any files from /RawContent dir.
# Any file in /RawContent dir will be managed by git lfs.
!/RawContent/**/*

!README.md
!build.ps1

# OS/platform generated files.

# Windows
ehthumbs.db
Thumbs.db

# Mac OS X
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory

# vim
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]
*.un~
Session.vim
.netrwhist

# Visual Studio
.vs